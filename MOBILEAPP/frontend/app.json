{
  "expo": {
    "name": "AKM",
    "slug": "akm",
    "scheme": "akm-app",
    "version": "2.5.49",
    "orientation": "portrait",
    "icon": "./assets/applogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/logo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akm.sync",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "AKM uses your location to share your live position with your dispatch team while you are on duty.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AKM shares your live location with your dispatch team while you are on duty, including when the app is in the background.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "name": "AKM",
      "icon": "./assets/applogo.png",
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/applogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.akm.sync",
      "launchMode": "singleTask",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyACI3bm9Mno0-DeH3BiSQ69Y_wSV_PMe9g"
        }
      },
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AKM uses your location to share your live position with your dispatch team while you are on duty.",
          "locationAlwaysAndWhenInUsePermission": "AKM shares your live location with your dispatch team while you are on duty, including when the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/jo.mp3",
            "./assets/sounds/so.mp3",
            "./assets/sounds/wo.mp3"
          ]
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AKM to access your photos to select job order images.",
          "savePhotosPermission": "Allow AKM to save taken photos to your phone gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AKM to access your photos to select job order images.",
          "cameraPermission": "Allow AKM to access your camera to take job order pictures."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3adab6a6-35b7-4ca3-b104-24624a17fc91"
      }
    }
  }
}